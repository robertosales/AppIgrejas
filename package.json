{
  "name": "appigrejas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev -w apps/admin",
    "dev:mobile": "npm run dev -w apps/mobile",
    "build:admin": "npm run build -w apps/admin",
    "lint": "npm run lint --workspaces-if-present",
    "typecheck": "npm run typecheck --workspaces-if-present"
  },
  "engines": {
    "node": ">=18"
  }
}
